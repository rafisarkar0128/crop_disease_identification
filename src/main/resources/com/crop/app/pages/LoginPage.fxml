<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="640.0" prefWidth="960.0" styleClass="app-root"
    stylesheets="@../styles/LoginPage.css"
    xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.crop.app.gui.controller.LoginPageController">
    <ImageView fx:id="backgroundImage" pickOnBounds="true" preserveRatio="true"
        StackPane.alignment="CENTER">
        <image>
            <Image url="@../images/background.png" />
        </image>
    </ImageView>
    <BorderPane prefHeight="640.0" prefWidth="960.0" styleClass="auth-shell">
        <center>
            <VBox maxWidth="460.0" maxHeight="460.0" styleClass="auth-card">
                <Label text="Welcome back" styleClass="page-title" />
                <Label text="Enter your credentials to continue." styleClass="page-subtitle"
                    wrapText="true" maxWidth="380.0" />
                <TextField fx:id="usernameField" promptText="Username or email"
                    styleClass="auth-field" maxWidth="380.0" />
                <PasswordField fx:id="passwordField" promptText="Password" styleClass="auth-field"
                    maxWidth="380.0" />
                <Label fx:id="statusLabel" text="" wrapText="true" styleClass="status-text"
                    maxWidth="380.0" />
                <VBox styleClass="action-stack">
                    <Button mnemonicParsing="false" onAction="#handleSignIn" text="Sign In"
                        styleClass="signin-button" maxWidth="1.7976931348623157E308" />
                    <Button mnemonicParsing="false" onAction="#toSignUpPage" text="Sign Up"
                        styleClass="signup-button" maxWidth="1.7976931348623157E308" />
                </VBox>
            </VBox>
        </center>
    </BorderPane>
</StackPane>
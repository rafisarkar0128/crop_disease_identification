<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="rootPane" prefHeight="640.0" prefWidth="960.0" styleClass="app-root"
    stylesheets="@../styles/SignupPage.css"
    xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.crop.app.gui.controller.SignupPageController">
    <ImageView fx:id="backgroundImage" pickOnBounds="true" preserveRatio="true"
        StackPane.alignment="CENTER">
        <image>
            <Image url="@../images/background.png" />
        </image>
    </ImageView>
    <BorderPane fx:id="authShell" prefHeight="640.0" prefWidth="960.0" styleClass="auth-shell">
        <center>
            <VBox prefHeight="640.0" prefWidth="960.0" alignment="CENTER_LEFT" maxWidth="520.0"
                maxHeight="540.0"
                styleClass="auth-card">
                <Label text="Create your account" styleClass="page-title" />
                <Label text="Fill in all fields to create a new account."
                    styleClass="page-subtitle"
                    wrapText="true" maxWidth="420.0" />
                <TextField fx:id="usernameField" promptText="Username"
                    styleClass="auth-field"
                    maxWidth="420.0" />
                <TextField fx:id="emailField" promptText="Email" styleClass="auth-field"
                    maxWidth="420.0" />
                <PasswordField fx:id="passwordField" promptText="Password"
                    styleClass="auth-field" maxWidth="420.0" />
                <PasswordField fx:id="confirmPasswordField" promptText="Confirm password"
                    styleClass="auth-field" maxWidth="420.0" />
                <Label fx:id="statusLabel" text="" wrapText="true" styleClass="status-text"
                    maxWidth="420.0" />
                <VBox styleClass="action-stack">
                    <Button mnemonicParsing="false" onAction="#handleSignUp"
                        text="Sign Up"
                        styleClass="signup-button" maxWidth="1.7976931348623157E308" />
                    <Button mnemonicParsing="false" onAction="#handleBackToLogin"
                        text="Back to Login"
                        styleClass="signin-button" maxWidth="1.7976931348623157E308" />
                </VBox>
            </VBox>
        </center>
    </BorderPane>
</StackPane>